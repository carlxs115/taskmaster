<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.EditProfileController"
      spacing="0" styleClass="dialog-body">

    <HBox styleClass="dialog-header" alignment="CENTER_LEFT" spacing="10">
        <FontIcon iconLiteral="fas-user-edit" styleClass="dialog-title-icon"/>
        <Label text="%profile.edit.dialog.title" styleClass="dialog-header-title"/>
    </HBox>

    <VBox spacing="16" style="-fx-padding: 24;">
        <VBox spacing="6">
            <Label text="%common.username" styleClass="dialog-field-label-bold"/>
            <TextField fx:id="usernameField" styleClass="security-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="%common.email" styleClass="dialog-field-label-bold"/>
            <TextField fx:id="emailField" styleClass="security-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="%common.birthdate" styleClass="dialog-field-label-bold"/>
            <DatePicker fx:id="birthDatePicker" styleClass="dialog-combo"
                        maxWidth="Infinity"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="dialog-error" visible="false" managed="false"/>

        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
            <Button text="%common.cancel" onAction="#handleCancel" styleClass="button, btn-cancel-soft"
                    contentDisplay="LEFT" graphicTextGap="6">
                <graphic>
                    <FontIcon iconLiteral="fas-times" styleClass="btn-cancel-soft-icon"/>
                </graphic>
            </Button>
            <Button text="%settings.save" onAction="#handleSave" styleClass="btn-confirm-accent"
                    contentDisplay="LEFT" graphicTextGap="6">
                <graphic>
                    <FontIcon iconLiteral="fas-check" styleClass="btn-confirm-accent-icon"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
