<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.AddWorkLogController"
      spacing="16" styleClass="dialog-root">

    <Label text="%common.worklog.add.title" styleClass="dialog-title"/>

    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%worklog.date" styleClass="dialog-field-label"/>
            <DatePicker fx:id="datePicker" maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%worklog.hours" styleClass="dialog-field-label"/>
            <TextField fx:id="hoursField" promptText="ej. 1.5" styleClass="dialog-field"/>
        </VBox>
    </HBox>
    <VBox spacing="6">
        <Label text="%worklog.activity.type" styleClass="dialog-field-label"/>
        <ComboBox fx:id="activityTypeCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%worklog.note" styleClass="dialog-field-label"/>
        <TextArea fx:id="noteField" promptText="%worklog.note.prompt"
                  styleClass="dialog-textarea" wrapText="true"
                  style="-fx-pref-height: 120px;"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="dialog-error" visible="false" managed="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%common.cancel" onAction="#handleCancel" styleClass="btn-cancel-soft"/>
        <Button text="%worklog.save" onAction="#handleSave" styleClass="btn-confirm-accent"/>
    </HBox>
</VBox>