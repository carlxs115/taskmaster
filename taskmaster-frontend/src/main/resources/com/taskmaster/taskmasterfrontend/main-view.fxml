<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskmaster.taskmasterfrontend.controller.MainController"
            style="-fx-background-color: #f0f0f5;">

    <!-- ===== TOPBAR APP ===== -->
    <top>
        <HBox style="-fx-background-color: #13131f; -fx-padding: 13 20 13 20;
                     -fx-border-color: #2a2a3e; -fx-border-width: 0 0 1 0;"
              alignment="CENTER_LEFT" spacing="12">
            <HBox spacing="0" onMouseClicked="#handleGoHome" style="-fx-cursor: hand;">
                <Label text="Task"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Master"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Avatar circular con iniciales + desplegable -->
            <Button fx:id="userMenuButton"
                    onAction="#handleUserMenu"
                    style="-fx-background-color: #2a1f4e; -fx-text-fill: #a78bfa;
                           -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-background-radius: 18px; -fx-min-width: 36px; -fx-min-height: 36px;
                           -fx-max-width: 36px; -fx-max-height: 36px;
                           -fx-border-color: #3d2f6e; -fx-border-radius: 18px; -fx-border-width: 1;"/>
        </HBox>
    </top>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <center>
        <HBox>
            <!-- ===== SIDEBAR ===== -->
            <VBox style="-fx-background-color: #13131f; -fx-min-width: 220px; -fx-max-width: 220px;
                         -fx-border-color: #2a2a3e; -fx-border-width: 0 1 0 0;"
                  spacing="0">
                <padding><Insets top="16" bottom="16"/></padding>

                <Button fx:id="btnHome" text="🏠  Inicio"
                        onAction="#handleGoHome"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2a1f4e; -fx-text-fill: #a78bfa;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 8 16 8 18;"/>

                <Separator style="-fx-background-color: #2a2a3e;"/>

                <Label text="MIS TAREAS"
                       style="-fx-text-fill: #555570; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 12 16 4 16;"/>
                <Button fx:id="btnAllTasks" text="📋  Todas las tareas"
                        onAction="#handleAllTasks"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 7 16 7 16;"/>
                <Button fx:id="btnPersonal" text="👤  Personal"
                        onAction="#handleCategoryPersonal"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 7 16 7 16;"/>
                <Button fx:id="btnEstudios" text="📚  Estudios"
                        onAction="#handleCategoryEstudios"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 7 16 7 16;"/>
                <Button fx:id="btnTrabajo" text="💼  Trabajo"
                        onAction="#handleCategoryTrabajo"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 7 16 7 16;"/>

                <Separator style="-fx-background-color: #2a2a3e;"/>

                <Label text="MIS PROYECTOS"
                       style="-fx-text-fill: #555570; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 12 16 4 16;"/>

                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: #13131f; -fx-background: #13131f;
                                   -fx-border-color: transparent;">
                    <VBox fx:id="projectListContainer" spacing="0"
                          style="-fx-background-color: #13131f;"/>
                </ScrollPane>

                <Separator style="-fx-background-color: #2a2a3e;"/>
                <Button fx:id="btnSettings" text="⚙  Ajustes"
                        onAction="#handleSettings"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 8 16 8 16;"/>
                <Button fx:id="btnTrash" text="🗑  Papelera"
                        onAction="#handleTrash"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #9999bb;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                               -fx-padding: 8 16 8 16;"/>
            </VBox>

            <!-- ===== ÁREA PRINCIPAL ===== -->
            <VBox fx:id="mainArea" HBox.hgrow="ALWAYS" spacing="0"
                  style="-fx-background-color: #f0f0f5;">

                <!-- TOPBAR DEL ÁREA: título + búsqueda + botón Crear -->
                <HBox fx:id="areaTopBar"
                      style="-fx-background-color: white; -fx-padding: 14 20 14 20;
                             -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;"
                      alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="areaTitle" text="Inicio"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField"
                               promptText="🔍  Buscar tareas..."
                               onKeyReleased="#handleSearch"
                               style="-fx-font-size: 12px; -fx-padding: 6 12 6 12;
                                      -fx-background-radius: 20px; -fx-border-radius: 20px;
                                      -fx-border-color: #e8e8e8; -fx-border-width: 1;
                                      -fx-pref-width: 200px;"
                               managed="false" visible="false"/>
                    <Button fx:id="createButton" text="＋  Crear  ▾"
                            onAction="#handleCreateMenu"
                            style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-background-radius: 6px;
                                   -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
                </HBox>

                <!-- FILTROS (ocultos en home) -->
                <HBox fx:id="taskFiltersBar"
                      style="-fx-background-color: white; -fx-padding: 8 20 8 20;
                             -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;"
                      spacing="8" managed="false" visible="false">
                    <ComboBox fx:id="statusFilter" promptText="Estado"
                              style="-fx-font-size: 11px;" maxWidth="160"/>
                    <ComboBox fx:id="priorityFilter" promptText="Prioridad"
                              style="-fx-font-size: 11px;" maxWidth="160"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- CONTENIDO PRINCIPAL -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="taskContainer" spacing="0">
                        <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>
                        <Label fx:id="emptyLabel"
                               text="✨ No tienes tareas activas. ¡Crea una para empezar!"
                               style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;
                                      -fx-padding: 24 20 0 20;"/>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
