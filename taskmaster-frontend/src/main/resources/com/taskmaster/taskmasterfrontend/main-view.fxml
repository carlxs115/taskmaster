<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskmaster.taskmasterfrontend.controller.MainController"
            style="-fx-background-color: #f5f5f5;">

    <!-- ===== BARRA SUPERIOR ===== -->
    <top>
        <HBox style="-fx-background-color: #2d2d2d; -fx-padding: 12 20 12 20;"
              alignment="CENTER_LEFT" spacing="10">

            <Label text="TaskMaster"
                   onMouseClicked="#handleGoHome"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <!-- Espaciador para empujar los botones a la derecha -->
            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="usernameLabel"
                   style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>

            <Button text="⚙"
                    onAction="#handleSettings"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-font-size: 16px; -fx-cursor: hand;"/>

            <Button text="Cerrar sesión"
                    onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-background-radius: 4px; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <center>
        <HBox>

            <!-- ===== SIDEBAR IZQUIERDO ===== -->
            <VBox style="-fx-background-color: #2d2d2d; -fx-min-width: 220px; -fx-max-width: 220px;"
                  spacing="0">
                <padding>
                    <Insets top="20" right="0" bottom="20" left="0"/>
                </padding>

                <Button text="🏠 Proyectos y tareas"
                        onAction="#handleGoHome"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

                <Separator style="-fx-padding: 4 0 4 0;"/>

                <Label text="MIS TAREAS"
                       style="-fx-text-fill: #888888; -fx-font-size: 11px;
                  -fx-font-weight: bold; -fx-padding: 8 16 4 16;"/>

                <Button text="📋 Todas las tareas"
                        onAction="#handleAllTasks"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

                <Button text="👤 Personal"
                        onAction="#handleCategoryPersonal"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

                <Button text="📚 Estudios"
                        onAction="#handleCategoryEstudios"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

                <Button text="💼 Trabajo"
                        onAction="#handleCategoryTrabajo"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

                <Separator style="-fx-padding: 4 0 4 0;"/>

                <Label text="MIS PROYECTOS"
                       style="-fx-text-fill: #888888; -fx-font-size: 11px;
                  -fx-font-weight: bold; -fx-padding: 8 16 4 16;"/>

                <ScrollPane VBox.vgrow="ALWAYS"
                            fitToWidth="true"
                            style="-fx-background-color: transparent;
                       -fx-background: #3a3a3a;
                       -fx-border-color: transparent;">
                    <VBox fx:id="projectListContainer" spacing="0"
                          style="-fx-background-color: #3a3a3a;"/>
                </ScrollPane>

                <Button text="🗑 Papelera"
                        onAction="#handleTrash"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cccccc;
                   -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;
                   -fx-padding: 8 16 8 16;"/>

            </VBox>

            <!-- ===== PANEL CENTRAL - PROYECTOS ===== -->
            <VBox fx:id="projectsPanel" HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f5f5;
             -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 1;"
                  spacing="0">

                <!-- Cabecera proyectos -->
                <HBox style="-fx-background-color: white; -fx-padding: 12 16 12 16;
                         -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                      alignment="CENTER_LEFT" spacing="8">
                    <Label text="Proyectos"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo proyecto"
                            onAction="#handleNewProject"
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                                -fx-font-size: 11px; -fx-background-radius: 4px;
                                -fx-cursor: hand;"/>
                </HBox>

                <!-- Filtros proyectos -->
                <HBox style="-fx-background-color: white; -fx-padding: 8 16 8 16;
                         -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                      spacing="8">
                    <ComboBox fx:id="projectStatusFilter"
                              promptText="Estado"
                              onAction="#handleProjectStatusFilter"
                              style="-fx-font-size: 11px;" maxWidth="Infinity"
                              HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="projectPriorityFilter"
                              promptText="Prioridad"
                              onAction="#handleProjectPriorityFilter"
                              style="-fx-font-size: 11px;" maxWidth="Infinity"
                              HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Lista proyectos -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="projectCardsContainer" spacing="8">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>
                        <Label fx:id="emptyProjectsLabel"
                               text="No hay proyectos. ¡Crea uno!"
                               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
                    </VBox>
                </ScrollPane>

            </VBox>

            <!-- ===== PANEL DERECHO - TAREAS ===== -->
            <VBox fx:id="taskPanel" HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f5f5;" spacing="0">
                <!-- Cabecera tareas -->
                <HBox style="-fx-background-color: white; -fx-padding: 12 16 12 16;
                         -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                      alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="projectTitleLabel"
                           text="Tareas"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nueva tarea"
                            fx:id="newTaskButton"
                            onAction="#handleNewTask"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-font-size: 11px; -fx-background-radius: 4px;
                               -fx-cursor: hand;"/>
                </HBox>

                <!-- Filtros tareas -->
                <HBox style="-fx-background-color: white; -fx-padding: 8 16 8 16;
         -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                      spacing="8">
                    <ComboBox fx:id="statusFilter"
                              promptText="Estado"
                              style="-fx-font-size: 11px;"
                              maxWidth="160"/>
                    <ComboBox fx:id="priorityFilter"
                              promptText="Prioridad"
                              style="-fx-font-size: 11px;"
                              maxWidth="160"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Lista tareas -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="taskContainer" spacing="8" alignment="CENTER">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>
                        <Label fx:id="emptyLabel"
                               text="✨ No tienes tareas activas. ¡Crea una para empezar!"
                               style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>
                    </VBox>
                </ScrollPane>

            </VBox>
        </HBox>
    </center>

</BorderPane>
