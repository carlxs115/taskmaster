<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskmaster.taskmasterfrontend.controller.MainController"
            styleClass="main-area">

    <!-- ===== TOPBAR APP ===== -->
    <top>
        <HBox styleClass="app-topbar" alignment="CENTER_LEFT" spacing="12">
            <HBox spacing="0" onMouseClicked="#handleGoHome" style="-fx-cursor: hand;">
                <Label text="Task"   styleClass="app-topbar-logo-task"/>
                <Label text="Master" styleClass="app-topbar-logo-master"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8" onMouseClicked="#handleUserMenu"
                  styleClass="app-topbar-user-pill">
                <StackPane fx:id="sidebarAvatarContainer"/>
                <Label fx:id="userMenuButton" styleClass="app-topbar-username"/>
                <FontIcon iconLiteral="fas-chevron-down" styleClass="topbar-user-chevron"/>
            </HBox>
        </HBox>
    </top>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <center>
        <HBox>
            <!-- ===== SIDEBAR ===== -->
            <VBox styleClass="sidebar" spacing="0">
                <padding><Insets top="16" bottom="16"/></padding>

                <Button fx:id="btnHome" text="%sidebar.home"
                        onAction="#handleGoHome"
                        maxWidth="Infinity"
                        styleClass="sidebar-btn-active"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-home" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Separator styleClass="sidebar-separator"/>

                <Label text="%sidebar.section.tasks" styleClass="sidebar-section-label"/>
                <Button fx:id="btnAllTasks" text="%sidebar.all.tasks"
                        onAction="#handleAllTasks"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-list-ul" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Button fx:id="btnPersonal" text="%sidebar.personal"
                        onAction="#handleCategoryPersonal"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-user" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Button fx:id="btnEstudios" text="%sidebar.estudios"
                        onAction="#handleCategoryEstudios"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-graduation-cap" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Button fx:id="btnTrabajo" text="%sidebar.trabajo"
                        onAction="#handleCategoryTrabajo"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-briefcase" styleClass="sidebar-icon"/></graphic>
                </Button>

                <Separator styleClass="sidebar-separator"/>
                <Label text="%sidebar.section.projects" styleClass="sidebar-section-label"/>

                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="sidebar-scroll">
                    <VBox fx:id="projectListContainer" styleClass="sidebar-project-list" spacing="0"/>
                </ScrollPane>

                <Separator styleClass="sidebar-separator"/>
                <Button fx:id="btnHelp" text="%sidebar.help"
                        onAction="#handleHelp"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-question-circle" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Separator styleClass="sidebar-separator"/>
                <Button fx:id="btnSettings" text="%sidebar.settings"
                        onAction="#handleSettings"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-cog" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Button fx:id="btnSecurity" text="%sidebar.security"
                        onAction="#handleSecurity"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" styleClass="sidebar-icon"/></graphic>
                </Button>
                <Button fx:id="btnTrash" text="%sidebar.trash"
                        onAction="#handleTrash"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        contentDisplay="LEFT" graphicTextGap="10">
                    <graphic><FontIcon iconLiteral="fas-trash" styleClass="sidebar-icon"/></graphic>
                </Button>
            </VBox>

            <!-- ===== ÁREA PRINCIPAL ===== -->
            <VBox fx:id="mainArea" HBox.hgrow="ALWAYS" spacing="0" styleClass="main-area">

                <!-- TOPBAR DEL ÁREA -->
                <HBox fx:id="areaTopBar" styleClass="area-topbar"
                      alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="areaTitle" text="%sidebar.home" styleClass="area-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox fx:id="searchContainer" styleClass="area-search-container"
                          alignment="CENTER_LEFT" spacing="6"
                          managed="false" visible="false">
                        <FontIcon iconLiteral="fas-search" styleClass="area-search-icon"/>
                        <TextField fx:id="searchField"
                                   promptText="%topbar.search.prompt"
                                   onKeyReleased="#handleSearch"
                                   styleClass="area-search-field-inner"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Button fx:id="createButton"
                            onAction="#handleCreateMenu"
                            styleClass="btn-create"
                            contentDisplay="GRAPHIC_ONLY">
                        <graphic>
                            <HBox alignment="CENTER" spacing="6">
                                <FontIcon iconLiteral="fas-plus" styleClass="btn-create-icon"/>
                                <Label text="%topbar.create" styleClass="btn-create-label"/>
                                <FontIcon iconLiteral="fas-chevron-down" styleClass="btn-create-chevron"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- FILTROS -->
                <HBox fx:id="taskFiltersBar" styleClass="filters-bar"
                      spacing="8" alignment="CENTER_LEFT" managed="false" visible="false">
                    <Label fx:id="filterLabel" text="%filter.label" styleClass="filter-label"/>
                    <ComboBox fx:id="statusFilter"   promptText="%common.status"   styleClass="filter-combo" prefWidth="130"/>
                    <ComboBox fx:id="priorityFilter" promptText="%common.priority" styleClass="filter-combo" prefWidth="130"/>
                    <Separator orientation="VERTICAL" style="-fx-padding: 0 4 0 4;"/>
                    <Label fx:id="sortLabel" text="%sort.label" styleClass="filter-label"/>
                    <ComboBox fx:id="sortFilter" promptText="%sort.criteria" styleClass="filter-combo" prefWidth="140"/>
                    <Button fx:id="sortDirectionBtn"
                            onAction="#handleSortDirection"
                            styleClass="sort-direction-btn">
                        <graphic>
                            <FontIcon fx:id="sortDirectionIcon"
                                      iconLiteral="fas-arrow-up"
                                      styleClass="sort-direction-icon"/>
                        </graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="clearFiltersBtn" text="%filter.clear"
                            onAction="#handleClearFilters"
                            styleClass="btn-clear-filters"
                            contentDisplay="LEFT" graphicTextGap="6">
                        <graphic>
                            <FontIcon iconLiteral="fas-times" styleClass="btn-clear-filters-icon"/>
                        </graphic>
                    </Button>
                </HBox>

                <!-- CONTENIDO -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="taskContainer" spacing="0">
                        <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>
                        <Label fx:id="emptyLabel"
                               text="%tasks.empty.default"
                               styleClass="empty-label"/>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
