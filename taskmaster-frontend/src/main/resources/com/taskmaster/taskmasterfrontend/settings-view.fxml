<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="settingsRoot"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.SettingsController"
      HBox.hgrow="ALWAYS"
      style="-fx-background-color: #f5f5f5;">

    <!-- Cabecera -->
    <HBox style="-fx-background-color: white; -fx-padding: 16 20 16 20;
                 -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT">
        <Label text="%settings.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
    </HBox>
    <!-- Contenido con scroll -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
    <VBox spacing="24" style="-fx-padding: 24;">

        <!-- ═══════════════════════════════════════════════════
             SECCIÓN: APARIENCIA
        ════════════════════════════════════════════════════ -->
        <Label text="%settings.section.appearance"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888;
                      -fx-padding: 4 0 0 2;"/>

        <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 20;
                                  -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 8px;">
            <Label text="%settings.theme.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.theme.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>

            <!-- Cuadrícula de temas generada dinámicamente -->
            <FlowPane fx:id="themesContainer"
                      hgap="10" vgap="10"
                      style="-fx-padding: 4 0 4 0;"/>

            <Label fx:id="themeStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
         SECCIÓN: FECHA Y HORA
        ════════════════════════════════════════════════════ -->
        <Label text="%settings.section.datetime"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888;
                  -fx-padding: 4 0 0 2;"/>

        <!-- Formato de fecha -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                               -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                               -fx-border-radius: 8px;">
            <Label text="%settings.dateformat.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.dateformat.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <ComboBox fx:id="dateFormatCombo"
                      style="-fx-font-size: 13px; -fx-pref-width: 220px;"/>
            <Button text="%settings.save"
                    onAction="#handleSaveDateFormat"
                    styleClass="btn-confirm"/>
            <Label fx:id="dateFormatStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

        <!-- Formato de horas -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                               -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                               -fx-border-radius: 8px;">
            <Label text="%settings.timeformat.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.timeformat.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="timeSystem" text="%settings.timeformat.system">
                    <toggleGroup>
                        <ToggleGroup fx:id="timeFormatGroup"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="time24h" text="%settings.timeformat.24h"
                             toggleGroup="$timeFormatGroup"/>
                <RadioButton fx:id="time12h" text="%settings.timeformat.12h"
                             toggleGroup="$timeFormatGroup"/>
            </HBox>
            <Button text="%settings.save"
                    onAction="#handleSaveTimeFormat"
                    styleClass="btn-confirm"/>
            <Label fx:id="timeFormatStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
         SECCIÓN: IDIOMA
        ════════════════════════════════════════════════════ -->
        <Label text="%settings.section.language"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888;
                  -fx-padding: 8 0 0 2;"/>

        <!-- Idioma -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                               -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                               -fx-border-radius: 8px;">
            <Label text="%settings.language.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.language.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="langEs" text="ES  Español">
                    <toggleGroup>
                        <ToggleGroup fx:id="languageGroup"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="langEn" text="EN  English"
                             toggleGroup="$languageGroup"/>
            </HBox>
            <Button text="%settings.language.apply"
                    onAction="#handleSaveLanguage"
                    styleClass="btn-confirm"/>
            <Label fx:id="languageStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
         SECCIÓN: PAPELERA
        ════════════════════════════════════════════════════ -->
        <Label text="%settings.section.trash"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888;
                  -fx-padding: 8 0 0 2;"/>

        <!-- Periodo de papelera -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                               -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                               -fx-border-radius: 8px;">
            <Label text="%settings.trash.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.trash.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="days7" text="%settings.trash.7days"
                             style="-fx-font-size: 13px;">
                    <toggleGroup>
                        <ToggleGroup fx:id="retentionGroup"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="days15" text="%settings.trash.15days"
                             toggleGroup="$retentionGroup"
                             style="-fx-font-size: 13px;"/>
                <RadioButton fx:id="days30" text="%settings.trash.30days"
                             toggleGroup="$retentionGroup"
                             style="-fx-font-size: 13px;"/>
            </HBox>
            <Button text="%settings.save"
                    onAction="#handleSaveRetention"
                    styleClass="btn-confirm"/>
            <Label fx:id="retentionStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

    </VBox>
    </ScrollPane>
</VBox>