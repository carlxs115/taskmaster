<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.SettingsController"
      HBox.hgrow="ALWAYS"
      style="-fx-background-color: #f5f5f5;">

    <!-- Cabecera -->
    <HBox style="-fx-background-color: white; -fx-padding: 16 20 16 20;
                 -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT">
        <Label text="%settings.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
    </HBox>

    <VBox spacing="24" style="-fx-padding: 24;">

        <!-- Periodo de papelera -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                                   -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                                   -fx-border-radius: 8px;">

            <Label text="%settings.trash.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

            <Label text="%settings.trash.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="days7" text="%settings.trash.7days"
                             style="-fx-font-size: 13px;">
                    <toggleGroup>
                        <ToggleGroup fx:id="retentionGroup"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="days15" text="%settings.trash.15days"
                             toggleGroup="$retentionGroup"
                             style="-fx-font-size: 13px;"/>
                <RadioButton fx:id="days30" text="%settings.trash.30days"
                             toggleGroup="$retentionGroup"
                             style="-fx-font-size: 13px;"/>
            </HBox>

            <Button text="%settings.save"
                    onAction="#handleSaveRetention"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-background-radius: 4px; -fx-cursor: hand;
                           -fx-font-size: 13px;"/>

            <Label fx:id="retentionStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

        <!-- Idioma -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20;
                           -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                           -fx-border-radius: 8px;">
            <Label text="%settings.language.title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
            <Label text="%settings.language.description"
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <RadioButton fx:id="langEs" text="🇪🇸  Español">
                    <toggleGroup>
                        <ToggleGroup fx:id="languageGroup"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="langEn" text="🇬🇧  English"
                             toggleGroup="$languageGroup"/>
            </HBox>
            <Button text="%settings.language.apply"
                    onAction="#handleSaveLanguage"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-background-radius: 4px; -fx-cursor: hand;
                   -fx-font-size: 13px;"/>
            <Label fx:id="languageStatusLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;"
                   visible="false"/>
        </VBox>

    </VBox>

</VBox>