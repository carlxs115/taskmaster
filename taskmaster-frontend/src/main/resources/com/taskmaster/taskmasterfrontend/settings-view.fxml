<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="settingsRoot"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.SettingsController"
      HBox.hgrow="ALWAYS"
      styleClass="profile-root">

    <!-- Cabecera -->
    <HBox styleClass="profile-header" alignment="CENTER_LEFT">
        <Label text="%settings.title" styleClass="profile-header-title"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="24" style="-fx-padding: 24;">

            <!-- APARIENCIA -->
            <Label text="%settings.section.appearance" styleClass="sidebar-section-label"/>
            <VBox spacing="14" styleClass="card">
                <Label text="%settings.theme.title" styleClass="profile-section-title"/>
                <Label text="%settings.theme.description" styleClass="stat-card-label"/>
                <FlowPane fx:id="themesContainer" hgap="10" vgap="10"
                          style="-fx-padding: 4 0 4 0;"/>
                <Label fx:id="themeStatusLabel" styleClass="profile-rate-value" visible="false"/>
            </VBox>

            <!-- FECHA Y HORA -->
            <Label text="%settings.section.datetime" styleClass="sidebar-section-label"/>
            <VBox spacing="12" styleClass="card">
                <Label text="%settings.dateformat.title" styleClass="profile-section-title"/>
                <Label text="%settings.dateformat.description" styleClass="stat-card-label"/>
                <ComboBox fx:id="dateFormatCombo" styleClass="dialog-combo"
                          style="-fx-pref-width: 220px;"/>
                <Button text="%settings.save" onAction="#handleSaveDateFormat"
                        styleClass="btn-confirm-accent"/>
                <Label fx:id="dateFormatStatusLabel" styleClass="profile-rate-value" visible="false"/>
            </VBox>

            <VBox spacing="12" styleClass="card">
                <Label text="%settings.timeformat.title" styleClass="profile-section-title"/>
                <Label text="%settings.timeformat.description" styleClass="stat-card-label"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <RadioButton fx:id="timeSystem" text="%settings.timeformat.system">
                        <toggleGroup><ToggleGroup fx:id="timeFormatGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="time24h" text="%settings.timeformat.24h"
                                 toggleGroup="$timeFormatGroup"/>
                    <RadioButton fx:id="time12h" text="%settings.timeformat.12h"
                                 toggleGroup="$timeFormatGroup"/>
                </HBox>
                <Button text="%settings.save" onAction="#handleSaveTimeFormat"
                        styleClass="btn-confirm-accent"/>
                <Label fx:id="timeFormatStatusLabel" styleClass="profile-rate-value" visible="false"/>
            </VBox>

            <!-- IDIOMA -->
            <Label text="%settings.section.language" styleClass="sidebar-section-label"/>
            <VBox spacing="12" styleClass="card">
                <Label text="%settings.language.title" styleClass="profile-section-title"/>
                <Label text="%settings.language.description" styleClass="stat-card-label"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <RadioButton fx:id="langEs" text="ES  Español">
                        <toggleGroup><ToggleGroup fx:id="languageGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="langEn" text="EN  English"
                                 toggleGroup="$languageGroup"/>
                </HBox>
                <Button text="%settings.language.apply" onAction="#handleSaveLanguage"
                        styleClass="btn-confirm-accent"/>
                <Label fx:id="languageStatusLabel" styleClass="profile-rate-value" visible="false"/>
            </VBox>

            <!-- PAPELERA -->
            <Label text="%settings.section.trash" styleClass="sidebar-section-label"/>
            <VBox spacing="12" styleClass="card">
                <Label text="%settings.trash.title" styleClass="profile-section-title"/>
                <Label text="%settings.trash.description" styleClass="stat-card-label"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <RadioButton fx:id="days7" text="%settings.trash.7days">
                        <toggleGroup><ToggleGroup fx:id="retentionGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="days15" text="%settings.trash.15days"
                                 toggleGroup="$retentionGroup"/>
                    <RadioButton fx:id="days30" text="%settings.trash.30days"
                                 toggleGroup="$retentionGroup"/>
                </HBox>
                <Button text="%settings.save" onAction="#handleSaveRetention"
                        styleClass="btn-confirm-accent"/>
                <Label fx:id="retentionStatusLabel" styleClass="profile-rate-value" visible="false"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>