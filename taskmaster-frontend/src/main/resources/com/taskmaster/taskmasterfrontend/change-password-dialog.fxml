<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.ChangePasswordController"
      spacing="0" styleClass="dialog-body">

    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <Label text="%security.password.button" styleClass="dialog-header-title"/>
    </HBox>

    <VBox spacing="16" style="-fx-padding: 24;">
        <VBox spacing="6">
            <Label text="%security.password.current" styleClass="dialog-field-label-bold"/>
            <PasswordField fx:id="currentPasswordField" styleClass="security-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="%security.password.new" styleClass="dialog-field-label-bold"/>
            <PasswordField fx:id="newPasswordField" styleClass="security-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="%security.password.confirm" styleClass="dialog-field-label-bold"/>
            <PasswordField fx:id="confirmPasswordField" styleClass="security-field"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="dialog-error" visible="false" managed="false"/>

        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
            <Button text="%common.cancel" onAction="#handleCancel" styleClass="button, btn-cancel-soft"/>
            <Button text="%security.password.button" onAction="#handleSave"
                    styleClass="btn-confirm-accent"/>
        </HBox>
    </VBox>
</VBox>
