<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.ChangePasswordController"
      spacing="0"
      style="-fx-background-color: #f0f0f5;">

    <!-- Cabecera -->
    <HBox style="-fx-background-color: white; -fx-padding: 16 20 16 20;
                 -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT">
        <Label text="%security.password.button"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;"/>
    </HBox>

    <VBox spacing="16" style="-fx-padding: 24;">

        <VBox spacing="6">
            <Label text="%security.password.current"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555555;"/>
            <PasswordField fx:id="currentPasswordField"
                           style="-fx-font-size: 13px; -fx-padding: 8 12 8 12;
                                  -fx-background-radius: 6px; -fx-border-color: #e8e8e8;
                                  -fx-border-radius: 6px; -fx-border-width: 1;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="%security.password.new"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555555;"/>
            <PasswordField fx:id="newPasswordField"
                           style="-fx-font-size: 13px; -fx-padding: 8 12 8 12;
                                  -fx-background-radius: 6px; -fx-border-color: #e8e8e8;
                                  -fx-border-radius: 6px; -fx-border-width: 1;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="%security.password.confirm"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555555;"/>
            <PasswordField fx:id="confirmPasswordField"
                           style="-fx-font-size: 13px; -fx-padding: 8 12 8 12;
                                  -fx-background-radius: 6px; -fx-border-color: #e8e8e8;
                                  -fx-border-radius: 6px; -fx-border-width: 1;"/>
        </VBox>

        <Label fx:id="errorLabel"
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
               visible="false" managed="false"/>

        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
            <Button text="%common.cancel"
                    onAction="#handleCancel"
                    style="-fx-background-color: #f0f0f5; -fx-text-fill: #555555;
                           -fx-font-size: 13px; -fx-background-radius: 6px;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
            <Button text="%security.password.button"
                    onAction="#handleSave"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-background-radius: 6px;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
        </HBox>
    </VBox>
</VBox>
