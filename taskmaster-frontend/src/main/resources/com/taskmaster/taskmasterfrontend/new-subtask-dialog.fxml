<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.NewSubtaskController"
      spacing="16" styleClass="dialog-root">

    <Label text="%new.subtask.title" styleClass="dialog-title"/>

    <VBox spacing="6">
        <Label text="%common.title.field" styleClass="dialog-field-label"/>
        <TextField fx:id="titleField"
                   promptText="%new.subtask.title.prompt"
                   styleClass="dialog-field"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%common.description" styleClass="dialog-field-label"/>
        <TextArea fx:id="descriptionField"
                  promptText="%common.description.prompt"
                  styleClass="dialog-textarea" wrapText="true"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%common.priority" styleClass="dialog-field-label"/>
        <ComboBox fx:id="priorityCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="dialog-error" visible="false" managed="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%common.cancel" onAction="#handleCancel" styleClass="btn-cancel-soft"/>
        <Button text="%new.subtask.button" onAction="#handleCreate" styleClass="btn-confirm-accent"/>
    </HBox>
</VBox>