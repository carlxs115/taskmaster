<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.NewSubtaskController"
      spacing="16"
      style="-fx-background-color: white; -fx-padding: 24;">

    <Label text="%new.subtask.title"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;"/>

    <VBox spacing="6">
        <Label text="%new.subtask.title.field" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <TextField fx:id="titleField"
                   promptText="%new.subtask.title.prompt"
                   style="-fx-pref-height: 38px;"/>
    </VBox>

    <VBox spacing="6">
        <Label text="%new.subtask.description" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <TextArea fx:id="descriptionField"
                  promptText="%new.subtask.description.prompt"
                  style="-fx-pref-height: 80px;"
                  wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="%priority" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <ComboBox fx:id="priorityCombo"
                  maxWidth="Infinity"
                  style="-fx-pref-height: 38px;"/>
    </VBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
           visible="false" managed="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%dialog.cancel"
                onAction="#handleCancel"
                style="-fx-background-color: #f0f0f5; -fx-text-fill: #555555;
                       -fx-background-radius: 6px; -fx-cursor: hand;
                       -fx-padding: 8 16 8 16;"/>
        <Button text="%new.subtask.button"
                onAction="#handleCreate"
                style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                       -fx-background-radius: 6px; -fx-cursor: hand;
                       -fx-padding: 8 16 8 16;"/>
    </HBox>
</VBox>