<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- TÍTULO -->
    <Label text="TaskMaster"
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

    <Label text="Inicia sesión en tu cuenta"
           style="-fx-font-size: 14px; -fx-text-fill: #888888;"/>

    <!-- FORMULARIO -->
    <VBox spacing="8">
        <Label text="Usuario" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <TextField fx:id="usernameField"
                   promptText="Introduce tu usuario"
                   style="-fx-pref-height: 40px; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Contraseña" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <PasswordField fx:id="passwordField"
                       promptText="Introduce tu contraseña"
                       style="-fx-pref-height: 40px; -fx-font-size: 13px;"/>
    </VBox>

    <!-- MENSAJE DE ERROR -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
           visible="false"/>

    <!-- BOTÓN LOGIN -->
    <Button text="Iniciar sesión"
            fx:id="loginButton"
            onAction="#handleLogin"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;
                   -fx-background-radius: 6px; -fx-cursor: hand;"
            maxWidth="Infinity"/>

    <!-- ENLACE REGISTRO -->
    <HBox alignment="CENTER" spacing="5">
        <Label text="¿No tienes cuenta?" style="-fx-text-fill: #888888;"/>
        <Hyperlink text="Regístrate"
                   fx:id="registerLink"
                   onAction="#handleGoToRegister"
                   style="-fx-text-fill: #3498db;"/>
    </HBox>

</VBox>