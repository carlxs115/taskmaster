<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.LoginController" styleClass="auth-root">

    <!-- ENCABEZADO OSCURO -->
    <VBox styleClass="auth-header" alignment="CENTER" spacing="8">
        <HBox alignment="CENTER">
            <Label text="Task"   styleClass="auth-title-task"/>
            <Label text="Master" styleClass="auth-title-master"/>
        </HBox>
        <Label text="%login.subtitle" styleClass="auth-subtitle"/>
    </VBox>

    <!-- CUERPO BLANCO -->
    <VBox styleClass="auth-body" spacing="16">

        <!-- FORMULARIO -->
        <VBox spacing="8">
            <Label text="%login.identifier.label" styleClass="auth-field-label"/>
            <TextField fx:id="usernameField"
                       promptText="%login.identifier.prompt"
                       styleClass="auth-field"/>
        </VBox>
        <VBox spacing="8">
            <Label text="%common.password" styleClass="auth-field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="%common.password.prompt"
                           styleClass="auth-field"/>
        </VBox>

        <!-- ERROR -->
        <Label fx:id="errorLabel" styleClass="auth-error" visible="false"/>

        <!-- BOTÓN -->
        <Button text="%login.button"
                fx:id="loginButton"
                onAction="#handleLogin"
                styleClass="auth-btn"
                maxWidth="Infinity"/>

        <!-- ENLACE REGISTRO -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="%login.no.account" styleClass="auth-link-label"/>
            <Hyperlink text="%login.register.link"
                       fx:id="registerLink"
                       onAction="#handleGoToRegister"
                       styleClass="auth-link"/>
        </HBox>
    </VBox>
</VBox>