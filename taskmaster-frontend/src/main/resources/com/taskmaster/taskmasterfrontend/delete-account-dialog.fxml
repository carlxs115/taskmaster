<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.DeleteAccountController"
      spacing="0" styleClass="dialog-body">

    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <Label text="%common.delete.account" styleClass="dialog-header-title-danger"/>
    </HBox>

    <VBox spacing="16" style="-fx-padding: 24;">
        <VBox spacing="8" styleClass="dialog-warning-box">
            <Label text="%delete.account.warning" styleClass="dialog-warning-title"/>
            <Label text="%delete.account.warning.detail"
                   styleClass="dialog-warning-desc" wrapText="true"/>
        </VBox>
        <VBox spacing="6">
            <Label text="%delete.account.password.prompt" styleClass="dialog-field-label-bold"/>
            <PasswordField fx:id="passwordField" styleClass="security-field"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="dialog-error" visible="false" managed="false"/>

        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
            <Button text="%common.cancel" onAction="#handleCancel" styleClass="btn-cancel-soft"/>
            <Button text="%common.delete.account" onAction="#handleDelete" styleClass="btn-danger"/>
        </HBox>
    </VBox>
</VBox>