<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.ActivityLogSectionController"
      spacing="8" styleClass="activity-log-section">
    <padding><Insets top="16" bottom="8" left="0" right="0"/></padding>
    <HBox alignment="CENTER" spacing="6">
        <FontIcon iconLiteral="fas-history" styleClass="actlog-title-icon"/>
        <Label text="%actlog.title" styleClass="section-title"/>
    </HBox>
    <TableView fx:id="activityTable" prefHeight="200" maxHeight="200"
               styleClass="activity-table">
        <columns>
            <TableColumn fx:id="colDate"   text="%actlog.col.date"   prefWidth="130"/>
            <TableColumn fx:id="colAction" text="%actlog.col.action" prefWidth="170"/>
            <TableColumn fx:id="colEntity" text="%actlog.col.entity" prefWidth="90"/>
            <TableColumn fx:id="colDetail" text="%actlog.col.detail" prefWidth="370"/>
        </columns>
        <placeholder><Label text="%actlog.empty"/></placeholder>
    </TableView>
</VBox>
