<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.RegisterController"
      alignment="CENTER"
      spacing="15"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- TÍTULO -->
    <Label text="TaskMaster"
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

    <Label text="%register.subtitle"
           style="-fx-font-size: 14px; -fx-text-fill: #888888;"/>

    <!-- FORMULARIO -->
    <VBox spacing="8">
        <Label text="%common.username" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <TextField fx:id="usernameField"
                   promptText="%common.username.prompt"
                   style="-fx-pref-height: 40px; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="%common.email" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <TextField fx:id="emailField"
                   promptText="%register.email.prompt"
                   style="-fx-pref-height: 40px; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="%common.password" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <PasswordField fx:id="passwordField"
                       promptText="%common.password.prompt"
                       style="-fx-pref-height: 40px; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="8">
        <Label text="%common.birthdate" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <DatePicker fx:id="birthDatePicker"
                    promptText="%common.birthdate.prompt"
                    style="-fx-pref-height: 40px; -fx-font-size: 13px; -fx-pref-width: 300px;"/>
    </VBox>

    <!-- MENSAJE DE ERROR -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
           visible="false"/>

    <!-- BOTÓN REGISTRO -->
    <Button text="%register.button"
            onAction="#handleRegister"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;
                   -fx-background-radius: 6px; -fx-cursor: hand;"
            maxWidth="Infinity"/>

    <!-- ENLACE LOGIN -->
    <HBox alignment="CENTER" spacing="5">
        <Label text="%register.has.account" style="-fx-text-fill: #888888;"/>
        <Hyperlink text="%register.login.link"
                   onAction="#handleGoToLogin"
                   style="-fx-text-fill: #3498db;"/>
    </HBox>

</VBox>