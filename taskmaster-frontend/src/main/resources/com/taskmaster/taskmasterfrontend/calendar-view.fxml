<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="root"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.CalendarController"
      styleClass="main-area">

    <!-- TOPBAR -->
    <HBox styleClass="area-topbar" alignment="CENTER_LEFT" spacing="12">
        <Label text="%sidebar.calendar" styleClass="area-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Navegación mes -->
        <HBox spacing="8" alignment="CENTER">
            <Button fx:id="btnPrev" onAction="#handlePrev"
                    styleClass="cal-nav-btn" contentDisplay="GRAPHIC_ONLY">
                <graphic><FontIcon iconLiteral="fas-chevron-left" styleClass="sidebar-icon"/></graphic>
            </Button>
            <Label fx:id="monthYearLabel" styleClass="cal-month-label" minWidth="160" alignment="CENTER"/>
            <Button fx:id="btnNext" onAction="#handleNext"
                    styleClass="cal-nav-btn" contentDisplay="GRAPHIC_ONLY">
                <graphic><FontIcon iconLiteral="fas-chevron-right" styleClass="sidebar-icon"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- GRID -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
        <GridPane fx:id="calendarGrid"
                  hgap="4" vgap="4"
                  maxWidth="Infinity" maxHeight="Infinity">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.28"/>
            </columnConstraints>
        </GridPane>
    </ScrollPane>
</VBox>