<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.AvatarCropController"
      spacing="16" styleClass="dialog-root">

    <Label text="%avatar.crop.title" styleClass="dialog-title"/>
    <Label text="%avatar.crop.description"
           styleClass="dialog-field-label" wrapText="true"/>

    <!-- Área de recorte circular -->
    <StackPane fx:id="cropContainer"
               style="-fx-background-color: -tm-bg-app;
                      -fx-border-color: -tm-topbar-user-border;
                      -fx-border-width: 2; -fx-border-radius: 128;
                      -fx-background-radius: 128;"
               minWidth="256" minHeight="256"
               maxWidth="256" maxHeight="256">
        <ImageView fx:id="imageView" fitWidth="256" fitHeight="256"/>
    </StackPane>

    <!-- Slider de zoom -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="🔍" style="-fx-font-size: 14px;"/>
        <Slider fx:id="zoomSlider" min="1.0" max="3.0" value="1.0"
                HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton" text="%common.cancel"
                onAction="#handleCancel" styleClass="button, btn-cancel-soft"/>
        <Button fx:id="saveButton" text="%avatar.crop.save"
                onAction="#handleSave" styleClass="btn-confirm-accent"/>
    </HBox>
</VBox>