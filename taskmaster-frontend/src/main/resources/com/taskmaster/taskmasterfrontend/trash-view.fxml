<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.TrashController"
      HBox.hgrow="ALWAYS"
      style="-fx-background-color: #f5f5f5;">

    <!-- Cabecera -->
    <HBox style="-fx-background-color: white; -fx-padding: 16 20 16 20;
                 -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="12">

        <Label text="%trash.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label fx:id="retentionLabel"
               style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
    </HBox>

    <!-- Pestañas -->
    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS"
             style="-fx-background-color: #f5f5f5;">

        <!-- Pestaña Tareas -->
        <Tab text="%trash.tab.tasks" closable="false">
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="trashTaskContainer" spacing="8">
                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20"/>
                    </padding>
                    <Label fx:id="emptyTasksLabel"
                           text="%trash.tasks.empty"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Pestaña Proyectos -->
        <Tab text="%trash.tab.projects" closable="false">
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="trashProjectContainer" spacing="8">
                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20"/>
                    </padding>
                    <Label fx:id="emptyProjectsLabel"
                           text="%trash.projects.empty"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 14px;"/>
                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>

</VBox>