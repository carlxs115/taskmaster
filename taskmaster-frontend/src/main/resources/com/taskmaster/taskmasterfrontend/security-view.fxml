<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.SecurityController"
      spacing="16" style="-fx-padding: 24; -fx-background-color: #f0f0f5;">

    <!-- Últimos accesos -->
    <VBox spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 10px;
                 -fx-border-color: #e8e8e8; -fx-border-radius: 10px; -fx-border-width: 1;">
        <HBox style="-fx-padding: 14 20 14 20; -fx-border-color: transparent transparent #f0f0f0 transparent;
                     -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT">
            <Label text="🕐  Últimos accesos"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;"/>
        </HBox>
        <VBox fx:id="accessLogContainer" spacing="0" style="-fx-padding: 0;">
            <Label fx:id="accessLogEmpty" text="No hay accesos registrados."
                   style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px; -fx-padding: 14 20 14 20;"/>
        </VBox>
    </VBox>

    <!-- Cambiar contraseña -->
    <VBox spacing="12"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-background-radius: 10px; -fx-border-color: #e8e8e8;
                 -fx-border-radius: 10px; -fx-border-width: 1;">
        <Label text="🔑  Cambiar contraseña"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e1e2e;"/>
        <PasswordField fx:id="currentPasswordField" promptText="Contraseña actual"
                       style="-fx-font-size: 12px; -fx-padding: 8 12 8 12;
                              -fx-background-radius: 6px; -fx-border-radius: 6px;
                              -fx-border-color: #e8e8e8; -fx-border-width: 1;"/>
        <PasswordField fx:id="newPasswordField" promptText="Nueva contraseña"
                       style="-fx-font-size: 12px; -fx-padding: 8 12 8 12;
                              -fx-background-radius: 6px; -fx-border-radius: 6px;
                              -fx-border-color: #e8e8e8; -fx-border-width: 1;"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmar nueva contraseña"
                       style="-fx-font-size: 12px; -fx-padding: 8 12 8 12;
                              -fx-background-radius: 6px; -fx-border-radius: 6px;
                              -fx-border-color: #e8e8e8; -fx-border-width: 1;"/>
        <Label fx:id="passwordErrorLabel" text=""
               style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;"
               visible="false" managed="false"/>
        <Button text="Cambiar contraseña" onAction="#handleChangePassword"
                style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-background-radius: 6px;
                       -fx-cursor: hand; -fx-padding: 7 16 7 16;"/>
    </VBox>

    <!-- Eliminar cuenta -->
    <VBox spacing="12"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-background-radius: 10px; -fx-border-color: #ffcccc;
                 -fx-border-radius: 10px; -fx-border-width: 1;">
        <Label text="⚠️  Zona de peligro"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
        <Label text="Eliminar tu cuenta es una acción permanente. Se borrarán todas tus tareas y proyectos."
               style="-fx-font-size: 12px; -fx-text-fill: #888888;" wrapText="true"/>
        <Button text="Eliminar cuenta" onAction="#handleDeleteAccount"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-background-radius: 6px;
                       -fx-cursor: hand; -fx-padding: 7 16 7 16;"/>
    </VBox>
</VBox>