<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.SecurityController"
      spacing="16" styleClass="security-root">

    <!-- Últimos accesos -->
    <VBox spacing="0" styleClass="security-card" style="-fx-padding: 0;">
        <HBox styleClass="security-access-row" alignment="CENTER_LEFT">
            <Label text="%security.access.log" styleClass="security-section-title"/>
        </HBox>
        <ScrollPane fitToWidth="true" maxHeight="220"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox fx:id="accessLogContainer" spacing="0">
                <Label fx:id="accessLogEmpty" text="%security.access.empty"
                       styleClass="security-access-empty"/>
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Cambiar contraseña -->
    <VBox spacing="12" styleClass="security-card">
        <Label text="%security.password.title" styleClass="security-section-title"/>
        <PasswordField fx:id="currentPasswordField"
                       promptText="%security.password.current" styleClass="security-field"/>
        <PasswordField fx:id="newPasswordField"
                       promptText="%security.password.new" styleClass="security-field"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="%security.password.confirm" styleClass="security-field"/>
        <Label fx:id="passwordErrorLabel" text=""
               styleClass="security-error" visible="false" managed="false"/>
        <Button text="%security.password.button" onAction="#handleChangePassword"
                styleClass="btn-primary"
                style="-fx-padding: 7 16 7 16; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Eliminar cuenta -->
    <VBox spacing="12" styleClass="security-card-danger">
        <Label text="%security.danger.title" styleClass="security-danger-title"/>
        <Label text="%security.danger.description"
               styleClass="security-danger-desc" wrapText="true"/>
        <Button text="%common.delete.account" onAction="#handleDeleteAccount"
                styleClass="btn-danger"/>
    </VBox>
</VBox>