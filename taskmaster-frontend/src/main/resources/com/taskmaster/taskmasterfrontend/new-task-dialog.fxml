<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.NewTaskController"
      spacing="16" styleClass="dialog-root">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <FontIcon iconLiteral="fas-plus-circle" styleClass="dialog-title-icon"/>
        <Label text="%new.task.title" styleClass="dialog-title"/>
    </HBox>

    <VBox spacing="6">
        <Label text="%common.title.field" styleClass="dialog-field-label"/>
        <TextField fx:id="titleField"
                   promptText="%new.task.title.prompt"
                   styleClass="dialog-field"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%common.description" styleClass="dialog-field-label"/>
        <TextArea fx:id="descriptionField"
                  promptText="%common.description.prompt"
                  styleClass="dialog-textarea" wrapText="true"/>
    </VBox>
    <VBox fx:id="categoryBox" spacing="6">
        <Label text="%common.new.category" styleClass="dialog-field-label"/>
        <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
    </VBox>
    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.priority" styleClass="dialog-field-label"/>
            <ComboBox fx:id="priorityCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.duedate" styleClass="dialog-field-label"/>
            <DatePicker fx:id="dueDatePicker" maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
        <VBox fx:id="projectBox" spacing="6">
            <Label text="%new.task.project" styleClass="dialog-field-label"/>
            <ComboBox fx:id="projectCombo" promptText="%new.task.project.prompt"
                      maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
    </HBox>

    <Label fx:id="errorLabel" styleClass="dialog-error" visible="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%common.cancel" onAction="#handleCancel" styleClass="btn-cancel-soft"
                contentDisplay="LEFT" graphicTextGap="6">
            <graphic>
                <FontIcon iconLiteral="fas-times" styleClass="btn-cancel-soft-icon"/>
            </graphic>
        </Button>
        <Button text="%new.task.button" onAction="#handleCreate" styleClass="btn-confirm-accent"
                contentDisplay="LEFT" graphicTextGap="6">
            <graphic>
                <FontIcon iconLiteral="fas-check" styleClass="btn-confirm-accent-icon"/>
            </graphic>
        </Button>
    </HBox>
</VBox>