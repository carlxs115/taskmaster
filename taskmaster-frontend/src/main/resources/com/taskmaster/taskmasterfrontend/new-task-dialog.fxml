<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.NewTaskController"
      spacing="16"
      style="-fx-background-color: white; -fx-padding: 24;">

    <Label text="%new.task.title"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

    <VBox spacing="6">
        <Label text="%common.title.field" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <TextField fx:id="titleField"
                   promptText="%new.task.title.prompt"
                   style="-fx-pref-height: 38px;"/>
    </VBox>

    <VBox spacing="6">
        <Label text="%common.description" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <TextArea fx:id="descriptionField"
                  promptText="%common.description.prompt"
                  style="-fx-pref-height: 80px;"
                  wrapText="true"/>
    </VBox>

    <VBox fx:id="categoryBox" spacing="6">
        <Label text="%common.new.category" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
        <ComboBox fx:id="categoryCombo"
                  maxWidth="Infinity"
                  style="-fx-pref-height: 38px;"/>
    </VBox>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.priority" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
            <ComboBox fx:id="priorityCombo"
                      maxWidth="Infinity"
                      style="-fx-pref-height: 38px;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.duedate" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
            <DatePicker fx:id="dueDatePicker"
                        maxWidth="Infinity"
                        style="-fx-pref-height: 38px;"/>
        </VBox>

        <VBox fx:id="projectBox" spacing="6">
            <Label text="%new.task.project" style="-fx-font-size: 13px; -fx-text-fill: #2d2d2d;"/>
            <ComboBox fx:id="projectCombo"
                      promptText="Sin proyecto (tarea personal)"
                      maxWidth="Infinity"
                      style="-fx-pref-height: 38px;"/>
        </VBox>
    </HBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"
           visible="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%common.cancel"
                onAction="#handleCancel"
                style="-fx-background-color: #e0e0e0; -fx-text-fill: #2d2d2d;
                       -fx-background-radius: 4px; -fx-cursor: hand;"/>
        <Button text="%new.task.button"
                onAction="#handleCreate"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-background-radius: 4px; -fx-cursor: hand;"/>
    </HBox>

</VBox>