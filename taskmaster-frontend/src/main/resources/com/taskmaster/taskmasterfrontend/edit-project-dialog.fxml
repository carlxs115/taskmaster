<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.taskmaster.taskmasterfrontend.controller.EditProjectController"
      spacing="16" styleClass="dialog-root">

    <Label text="%edit.project.title" styleClass="dialog-title"/>

    <VBox spacing="6">
        <Label text="%new.project.name" styleClass="dialog-field-label"/>
        <TextField fx:id="nameField" styleClass="dialog-field"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%common.description" styleClass="dialog-field-label"/>
        <TextArea fx:id="descriptionField"
                  styleClass="dialog-textarea" wrapText="true"/>
    </VBox>
    <VBox spacing="6">
        <Label text="%common.new.category" styleClass="dialog-field-label"/>
        <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
    </VBox>
    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.status" styleClass="dialog-field-label"/>
            <ComboBox fx:id="statusCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="%common.priority" styleClass="dialog-field-label"/>
            <ComboBox fx:id="priorityCombo" maxWidth="Infinity" styleClass="dialog-combo"/>
        </VBox>
    </HBox>

    <Label fx:id="errorLabel" styleClass="dialog-error" visible="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%common.cancel" onAction="#handleCancel" styleClass="btn-cancel"/>
        <Button text="%settings.save" onAction="#handleSave" styleClass="btn-confirm"/>
    </HBox>
</VBox>